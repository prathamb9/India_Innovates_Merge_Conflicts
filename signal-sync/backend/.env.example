# Copy this file to .env and adjust values as needed
# cp .env.example .env

# Database — must match docker-compose.yml
DATABASE_URL=postgresql+asyncpg://signalsync:signalsync_dev@localhost:5432/signalsync

# Redis
REDIS_URL=redis://localhost:6379/0

# Firebase — leave empty to skip (backend will still run without it)
FIREBASE_SERVICE_ACCOUNT_PATH=

# App
APP_ENV=development
SECRET_KEY=signalsync_dev_secret
